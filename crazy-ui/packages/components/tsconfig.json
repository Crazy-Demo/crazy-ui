{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "jsx": "preserve",
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*", "button/**/*", "input/**/*", "checkbox/**/*", "input-number/**/*", "form/**/*", "vue-shim.d.ts"],
  "exclude": ["node_modules", "dist", "**/tests/**"],
  "references": [
    { "path": "../core" },
    { "path": "../theme" }
  ]
}
