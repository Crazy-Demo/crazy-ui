{
  "name": "@crazy-ui/components",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./button/style": "./dist/button/style/index.css",
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./input/style": "./dist/input/style/index.css",
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js"
    },
    "./checkbox/style": "./dist/checkbox/style/index.css",
    "./input-number": {
      "types": "./dist/input-number/index.d.ts",
      "import": "./dist/input-number/index.js"
    },
    "./input-number/style": "./dist/input-number/style/index.css",
    "./select": {
      "types": "./dist/select/index.d.ts",
      "import": "./dist/select/index.js"
    },
    "./select/style": "./dist/select/style/index.css",
    "./menu": {
      "types": "./dist/menu/index.d.ts",
      "import": "./dist/menu/index.js"
    },
    "./menu/style": "./dist/menu/style/index.css",
    "./radio": {
      "types": "./dist/radio/index.d.ts",
      "import": "./dist/radio/index.js"
    },
    "./radio/style": "./dist/radio/style/index.css",
    "./switch": {
      "types": "./dist/switch/index.d.ts",
      "import": "./dist/switch/index.js"
    },
    "./switch/style": "./dist/switch/style/index.css",
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js"
    },
    "./tabs/style": "./dist/tabs/style/index.css",
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/form/index.js"
    },
    "./form/style": "./dist/form/style/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json && cp -r button/style dist/button/ && cp -r input/style dist/input/ && cp -r input-number/style dist/input-number/ && cp -r select/style dist/select/ && cp -r menu/style dist/menu/ && cp -r tabs/style dist/tabs/ && cp -r form/style dist/form/",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@crazy-ui/core": "workspace:*",
    "@crazy-ui/hooks": "workspace:*",
    "@crazy-ui/theme": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "@vue/test-utils": "^2.4.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "keywords": [
    "crazy-ui",
    "vue",
    "components",
    "ui"
  ],
  "author": "",
  "license": "MIT",
  "description": "Vue 3 components for Crazy UI"
}
